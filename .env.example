MODE=LOCAL

# WB API токены
WB_API_TOKEN=your_basic_or_personal_token_here

# Персональный токен — нужен для управления пользователями (/api/v1/users, /invite и т.д.)
# Если не задан — используется WB_API_TOKEN
WB_PERSONAL_TOKEN=

WB_API_BASE_URL=https://common-api.wildberries.ru

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=wb_user
DB_PASS=wb_pass
DB_NAME=wb_collector

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Grafana (логин/пароль для дашборда)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
